rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && currentUser().orgId == orgId;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && currentUser().role == 'admin';
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'orgId']) &&
             data.uid is string &&
             data.email is string &&
             data.orgId is string &&
             data.role in ['admin', 'sales', 'support', 'success', 'marketing'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['company', 'status', 'ownerId', 'createdAt', 'orgId']) &&
             data.company is string && data.company.size() < 100 &&
             data.status in ['new', 'contacted', 'qualified', 'lost'] &&
             data.ownerId is string &&
             data.createdAt is string &&
             data.orgId is string;
    }

    function writingToOwnOrg(data) {
      return isAuthenticated() && data.orgId == currentUser().orgId;
    }

    // ── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSelf(userId) && isValidUser(request.resource.data);
      allow update: if (isSelf(userId) || isOrgAdmin(resource.data.orgId)) && isValidUser(request.resource.data);
    }

    // ── Organizations ────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated();
      allow update: if isOrgAdmin(orgId);
    }

    // ── Leads ────────────────────────────────────────────────────────────────

    match /leads/{leadId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data) && isValidLead(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId) && isValidLead(request.resource.data);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Tickets ──────────────────────────────────────────────────────────────

    match /tickets/{ticketId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Campaigns ────────────────────────────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Customers ────────────────────────────────────────────────────────────

    match /customers/{customerId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Marketing Engagement ─────────────────────────────────────────────────

    match /marketingEngagement/{engagementId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Activities ───────────────────────────────────────────────────────────

    match /activities/{activityId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update, delete: if isOrgAdmin(resource.data.orgId);
    }

    // ── Tasks ────────────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if writingToOwnOrg(request.resource.data);
      allow update: if isOrgMember(resource.data.orgId);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }
  }
}
