rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, name, email, role, photoURL
    //
    // Collection: leads
    // Document ID: {leadId}
    // Fields: company, contactName, email, status, value, ownerId, createdAt
    //
    // Collection: tickets
    // Document ID: {ticketId}
    // Fields: subject, description, priority, status, customerId, assignedTo, createdAt
    //
    // Collection: campaigns
    // Document ID: {campaignId}
    // Fields: name, type, status, budget, leadsGenerated, startDate
    //
    // Collection: customers
    // Document ID: {customerId}
    // Fields: name, healthScore, plan, renewalDate, successManagerId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rohitlokwani17@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'sales', 'support', 'success', 'marketing'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['company', 'status', 'ownerId', 'createdAt']) &&
             data.company is string && data.company.size() < 100 &&
             data.status in ['new', 'contacted', 'qualified', 'lost'] &&
             data.ownerId is string &&
             data.createdAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update: if isAuthenticated() && isValidLead(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    match /marketingEngagement/{engagementId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }
  }
}
